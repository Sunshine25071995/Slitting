rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, role (admin|operator), createdAt
    //
    // Collection: jobCards
    // Fields: jobNumber, date, sizes, micron, oneRollMeter, eachCoilQuantity, eachCoilRolls, status, createdBy, createdAt
    //
    // Collection: jobCards/{jobId}/entries
    // Fields: jobId, coilSize, grossWeight, coreWeight, netWeight, meter, operatorUid, timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "sunshinepolyfilm@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.role in ['admin', 'operator'] &&
             data.uid == request.auth.uid;
    }

    function isValidJobCard(data) {
      return data.keys().hasAll(['jobNumber', 'date', 'sizes', 'micron']) &&
             data.jobNumber is string && data.jobNumber.size() > 0 &&
             data.sizes is list && data.micron is number;
    }

    function isValidStatusUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
             request.resource.data.status in ['pending', 'in-progress', 'completed'];
    }

    function isValidEntry(data) {
      return data.keys().hasAll(['jobId', 'coilSize', 'grossWeight', 'coreWeight', 'netWeight', 'meter', 'operatorUid']) &&
             data.jobId is string &&
             data.coilSize is number &&
             data.grossWeight is number &&
             data.coreWeight is number &&
             data.netWeight is number &&
             data.meter is number &&
             data.operatorUid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isOwner(uid) && isValidUser(request.resource.data);
    }

    match /jobCards/{jobId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin() && isValidJobCard(request.resource.data);
      allow update: if (isAdmin() && isValidJobCard(request.resource.data)) || 
                     (isAuthenticated() && isValidStatusUpdate());

      match /entries/{entryId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidEntry(request.resource.data);
        allow update: if isAuthenticated() && (isAdmin() || (request.auth.uid == resource.data.operatorUid && isValidEntry(request.resource.data)));
        allow delete: if isAdmin();
      }
    }
  }
}
